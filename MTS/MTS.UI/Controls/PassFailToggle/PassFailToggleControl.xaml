<UserControl x:Class="MTS.UI.Controls.PassFailToggle.PassFailToggleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <StackPanel Orientation="Horizontal">

        <!-- PASS button -->
        <Border x:Name="PassBorder"
                Width="110" Height="40"
                CornerRadius="6,0,0,6"
                Cursor="Hand"
                BorderThickness="1,1,0,1"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource SurfaceElevatedBrush}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding SelectPassCommand, ElementName=Root}"/>
            </Border.InputBindings>
            <TextBlock x:Name="PassLabel"
                       Text="✓  PASS"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

        <!-- FAIL button -->
        <Border x:Name="FailBorder"
                Width="110" Height="40"
                CornerRadius="0,6,6,0"
                Cursor="Hand"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Background="{StaticResource SurfaceElevatedBrush}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding SelectFailCommand, ElementName=Root}"/>
            </Border.InputBindings>
            <TextBlock x:Name="FailLabel"
                       Text="✗  FAIL"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

    </StackPanel>
</UserControl>
