<UserControl x:Class="MTS.UI.Controls.OtherTextInput.OtherTextInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <!-- Default Collapsed; code-behind sets Visible only when IsOtherSelected=true -->
    <Border x:Name="Container"
            Visibility="Collapsed"
            Background="{StaticResource SurfaceElevatedBrush}"
            BorderBrush="{StaticResource InputBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12"
            Margin="0,6,0,0">

        <StackPanel>
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       Style="{StaticResource Label}"
                       Margin="0,0,0,6"/>

            <Border x:Name="InputBorder"
                    BorderThickness="1"
                    CornerRadius="5">
                <TextBox x:Name="NotesBox"
                         Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="60"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8,6"
                         Background="{StaticResource InputBackgroundBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderThickness="0"/>
            </Border>

            <!-- Required indicator -->
            <TextBlock x:Name="RequiredHint"
                       Text="This field is required when 'Other' is selected."
                       FontSize="11"
                       Foreground="{StaticResource FailBrush}"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>
