<UserControl x:Class="MTS.UI.Controls.LookupTableEditor.LookupTableEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================
             LEFT: list + action buttons
        ============================================================ -->
        <DockPanel Grid.Column="0">

            <!-- Buttons dock to the bottom so the list fills remaining space -->
            <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
                <WrapPanel>
                    <Button Content="+ Add"
                            Command="{Binding AddCommand, ElementName=Root}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" Margin="0,0,6,4"/>

                    <Button Content="Remove"
                            Command="{Binding RemoveCommand, ElementName=Root}"
                            CommandParameter="{Binding SelectedItem, ElementName=Root}"
                            Style="{StaticResource DangerButton}"
                            IsEnabled="{Binding HasSelection, ElementName=Root}"
                            Padding="12,6" Margin="0,0,6,4"/>

                    <Button Content="↑"
                            Command="{Binding MoveUpCommand, ElementName=Root}"
                            CommandParameter="{Binding SelectedItem, ElementName=Root}"
                            Style="{StaticResource GhostButton}"
                            IsEnabled="{Binding HasSelection, ElementName=Root}"
                            Padding="10,6" Margin="0,0,4,4"/>

                    <Button Content="↓"
                            Command="{Binding MoveDownCommand, ElementName=Root}"
                            CommandParameter="{Binding SelectedItem, ElementName=Root}"
                            Style="{StaticResource GhostButton}"
                            IsEnabled="{Binding HasSelection, ElementName=Root}"
                            Padding="10,6" Margin="0,0,0,4"/>
                </WrapPanel>
            </Border>

            <!-- List -->
            <ListBox ItemsSource="{Binding Items, ElementName=Root}"
                     SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                     Background="{StaticResource SurfaceBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayLabel}"
                                   Padding="4,2"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource NavSelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource NavHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>

        <!-- ============================================================
             DIVIDER
        ============================================================ -->
        <Border Grid.Column="1"
                Background="{StaticResource BorderBrush}"/>

        <!-- ============================================================
             RIGHT: detail panel
        ============================================================ -->
        <Grid Grid.Column="2" Margin="20,0,0,0">

            <!-- Placeholder — shown when nothing is selected -->
            <TextBlock Text="Select an item from the list, or click + Add to create one."
                       Style="{StaticResource Muted}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasSelection, ElementName=Root,
                                   Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Detail form — shown when an item is selected -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasSelection, ElementName=Root,
                                      Converter={StaticResource BoolToVisibility}}">
                <ContentControl Content="{Binding SelectedItem, ElementName=Root}"
                                ContentTemplate="{Binding DetailTemplate, ElementName=Root}"/>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
