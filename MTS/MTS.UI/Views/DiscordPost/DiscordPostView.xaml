<UserControl x:Class="MTS.UI.Views.DiscordPost.DiscordPostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DiscordPostViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="32,24" MaxWidth="640">
            <TextBlock Text="Discord Post" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Text="Compose and copy a Discord post for the ACD community."
                       Style="{StaticResource Muted}" Margin="0,0,0,24"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="POST CONTENT" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding PostText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" MinHeight="120"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    <Button Content="Copy to Clipboard"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CopyPostCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Button Content="← Back to Dashboard"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Left"/>
        </Border>
    </Grid>
</UserControl>
