<UserControl x:Class="MTS.UI.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels.Settings"
             xmlns:lte="clr-namespace:MTS.UI.Controls.LookupTableEditor"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>      <!-- Tab content -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             HEADER
        ================================================================ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Settings" Style="{StaticResource H1}"/>
            <TextBlock Text="Manage shows, call types, donors, and evaluation criteria. Changes are not applied until you click Save."
                       Style="{StaticResource Muted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ================================================================
             TAB CONTENT
        ================================================================ -->
        <TabControl Grid.Row="2">

            <!-- --------------------------------------------------------
                 TAB: Shows
            -------------------------------------------------------- -->
            <TabItem Header="Shows">
                <lte:LookupTableEditorControl
                    Items="{Binding Shows}"
                    SelectedItem="{Binding SelectedShow, Mode=TwoWay}"
                    AddCommand="{Binding AddShowCommand}"
                    RemoveCommand="{Binding RemoveShowCommand}"
                    MoveUpCommand="{Binding MoveShowUpCommand}"
                    MoveDownCommand="{Binding MoveShowDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Show Name" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="One-Time Amount ($)" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding OneTimeAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                 Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Monthly Amount ($)" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding MonthlyAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                 Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Gift Description" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding GiftDescription, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- --------------------------------------------------------
                 TAB: Call Types
            -------------------------------------------------------- -->
            <TabItem Header="Call Types">
                <lte:LookupTableEditorControl
                    Items="{Binding CallTypes}"
                    SelectedItem="{Binding SelectedCallType, Mode=TwoWay}"
                    AddCommand="{Binding AddCallTypeCommand}"
                    RemoveCommand="{Binding RemoveCallTypeCommand}"
                    MoveUpCommand="{Binding MoveCallTypeUpCommand}"
                    MoveDownCommand="{Binding MoveCallTypeDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <TextBlock Text="Category" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding CategoryOptions}"
                                          SelectedItem="{Binding Category}"
                                          Margin="0,4,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- --------------------------------------------------------
                 TAB: Donors  (three sub-tabs, one per donor category)
            -------------------------------------------------------- -->
            <TabItem Header="Donors">
                <TabItem.Resources>
                    <!-- Shared donor detail form used by all three sub-tabs -->
                    <DataTemplate x:Key="DonorDetailTemplate">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="First Name" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Last Name" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Address" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,12"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="City" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="State" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="ZIP" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding ZipCode, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Phone" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,12"/>

                            <TextBlock Text="Email" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,16"/>

                            <CheckBox Content="Enabled"
                                      IsChecked="{Binding IsEnabled}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabItem.Resources>

                <!-- Sub-tabs for the three donor categories -->
                <TabControl>
                    <TabItem Header="New Donors">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.NewDonors,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedNewDonor, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddNewDonorCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveNewDonorCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveNewDonorUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveNewDonorDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DetailTemplate="{StaticResource DonorDetailTemplate}"/>
                    </TabItem>

                    <TabItem Header="Existing Members">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.ExistingMembers,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedExistingMember, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddExistingMemberCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveExistingMemberCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveExistingMemberUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveExistingMemberDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DetailTemplate="{StaticResource DonorDetailTemplate}"/>
                    </TabItem>

                    <TabItem Header="Increase Sustaining">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.IncreaseSustaining,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedIncreaseSustaining, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddIncreaseSustainingCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveIncreaseSustainingCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveIncreaseSustainingUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveIncreaseSustainingDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DetailTemplate="{StaticResource DonorDetailTemplate}"/>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- --------------------------------------------------------
                 TAB: Supervisor Reasons
            -------------------------------------------------------- -->
            <TabItem Header="Supervisor Reasons">
                <lte:LookupTableEditorControl
                    Items="{Binding SupervisorReasons}"
                    SelectedItem="{Binding SelectedSupervisorReason, Mode=TwoWay}"
                    AddCommand="{Binding AddSupervisorReasonCommand}"
                    RemoveCommand="{Binding RemoveSupervisorReasonCommand}"
                    MoveUpCommand="{Binding MoveSupervisorReasonUpCommand}"
                    MoveDownCommand="{Binding MoveSupervisorReasonDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- --------------------------------------------------------
                 TAB: Fail Reasons
            -------------------------------------------------------- -->
            <TabItem Header="Fail Reasons">
                <lte:LookupTableEditorControl
                    Items="{Binding FailReasons}"
                    SelectedItem="{Binding SelectedFailReason, Mode=TwoWay}"
                    AddCommand="{Binding AddFailReasonCommand}"
                    RemoveCommand="{Binding RemoveFailReasonCommand}"
                    MoveUpCommand="{Binding MoveFailReasonUpCommand}"
                    MoveDownCommand="{Binding MoveFailReasonDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Is 'Other' (shows a required text field during grading)"
                                          IsChecked="{Binding IsOther}"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="Applies to Calls"
                                          IsChecked="{Binding AppliesToCalls}"
                                          Margin="0,0,0,4"/>

                                <CheckBox Content="Applies to Supervisor Transfers"
                                          IsChecked="{Binding AppliesToSupTransfers}"
                                          Margin="0,0,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- --------------------------------------------------------
                 TAB: Coaching Categories
            -------------------------------------------------------- -->
            <TabItem Header="Coaching">
                <lte:LookupTableEditorControl
                    Items="{Binding CoachingCategories}"
                    SelectedItem="{Binding SelectedCoachingCategory, Mode=TwoWay}"
                    AddCommand="{Binding AddCoachingCategoryCommand}"
                    RemoveCommand="{Binding RemoveCoachingCategoryCommand}"
                    MoveUpCommand="{Binding MoveCoachingCategoryUpCommand}"
                    MoveDownCommand="{Binding MoveCoachingCategoryDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Is 'Other' (shows coaching notes field during grading)"
                                          IsChecked="{Binding IsOther}"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="Applies to Calls"
                                          IsChecked="{Binding AppliesToCalls}"
                                          Margin="0,0,0,4"/>

                                <CheckBox Content="Applies to Supervisor Transfers"
                                          IsChecked="{Binding AppliesToSupTransfers}"
                                          Margin="0,0,0,12"/>

                                <Separator Margin="0,4,0,12"/>

                                <!-- Sub-items section -->
                                <TextBlock Text="Sub-Items" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                                <TextBlock Text="Sub-items appear as checkboxes under this category during grading."
                                           Style="{StaticResource Muted}" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ Add Sub-Item"
                                            Command="{Binding AddSubItemCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,5" Margin="0,0,6,0"/>
                                    <Button Content="Remove"
                                            Command="{Binding RemoveSubItemCommand}"
                                            CommandParameter="{Binding SelectedSubItem}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="10,5" Margin="0,0,6,0"/>
                                    <Button Content="↑"
                                            Command="{Binding MoveSubItemUpCommand}"
                                            CommandParameter="{Binding SelectedSubItem}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,5" Margin="0,0,4,0"/>
                                    <Button Content="↓"
                                            Command="{Binding MoveSubItemDownCommand}"
                                            CommandParameter="{Binding SelectedSubItem}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,5"/>
                                </StackPanel>

                                <!-- Sub-item list -->
                                <ListBox ItemsSource="{Binding SubItems}"
                                         SelectedItem="{Binding SelectedSubItem, Mode=TwoWay}"
                                         MinHeight="72" MaxHeight="150"
                                         Background="{StaticResource SurfaceBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"
                                         Margin="0,0,0,8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayLabel}" Padding="4,2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource NavSelectedBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Inline edit for selected sub-item label -->
                                <StackPanel Visibility="{Binding SelectedSubItem,
                                                        Converter={StaticResource NullToVisibility}}">
                                    <TextBlock Text="Sub-Item Label" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding SelectedSubItem.Label,
                                                   UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,12"/>
                                </StackPanel>

                                <Separator Margin="0,4,0,12"/>
                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

        </TabControl>

        <!-- ================================================================
             FOOTER ACTIONS
        ================================================================ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Back -->
            <Button Grid.Column="0"
                    Content="← Back"
                    Command="{Binding NavigateBackCommand}"
                    Style="{StaticResource GhostButton}"
                    Padding="16,10"/>

            <!-- Unsaved-changes indicator (centre) -->
            <TextBlock Grid.Column="1"
                       Text="● Unsaved changes"
                       Foreground="{StaticResource WarningBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Visibility="{Binding IsDirty,
                                   Converter={StaticResource BoolToVisibility}}"/>

            <!-- Save + Reset -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Style="{StaticResource DangerButton}"
                        Padding="16,10" Margin="0,0,8,0"/>

                <Button Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="24,10"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
