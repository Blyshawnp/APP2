<UserControl x:Class="MTS.UI.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels.Settings"
             xmlns:lte="clr-namespace:MTS.UI.Controls.LookupTableEditor"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>      <!-- Tab content -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             HEADER
        ================================================================ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Settings" Style="{StaticResource H1}"/>
            <TextBlock Text="Configure your profile, integrations, and lookup tables. Changes are not applied until you click Save."
                       Style="{StaticResource Muted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ================================================================
             TAB CONTENT
        ================================================================ -->
        <TabControl Grid.Row="2">

            <!-- ============================================================
                 TAB: General
            ============================================================ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="600">

                        <!-- Profile -->
                        <TextBlock Text="Profile" Style="{StaticResource H2}" Margin="0,0,0,16"/>

                        <TextBlock Text="Tester Name" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TesterName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Display Name" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,24"/>

                        <!-- URLs -->
                        <TextBlock Text="URLs" Style="{StaticResource H2}" Margin="0,0,0,16"/>

                        <TextBlock Text="Cert Form URL" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Cert Sheet URL" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CertSheetUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,24"/>

                        <!-- Theme -->
                        <TextBlock Text="Theme" Style="{StaticResource H2}" Margin="0,0,0,16"/>
                        <TextBlock Text="Restart the application after changing the theme for full effect."
                                   Style="{StaticResource Muted}" Margin="0,0,0,12"/>
                        <Button Content="Toggle Light / Dark"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ToggleThemeCommand}"
                                HorizontalAlignment="Left"
                                Padding="20,10"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================
                 TAB: Gemini AI
            ============================================================ -->
            <TabItem Header="Gemini AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="600">

                        <TextBlock Text="Gemini AI — Smart Summaries" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                        <TextBlock Text="Rewrites coaching and fail summaries into clean, professional language using Google's Gemini AI."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <CheckBox Content="Enable Gemini AI Summaries"
                                  IsChecked="{Binding GeminiEnabled}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,24"/>

                        <TextBlock Text="Coaching Summary Prompt" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBlock Text="Used to rewrite coaching notes into professional language."
                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding GeminiCoachingPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,20"/>

                        <TextBlock Text="Reason for Fail Prompt" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBlock Text="Used to rewrite fail reason notes into professional language."
                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding GeminiFailPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================
                 TAB: Google Sheets
            ============================================================ -->
            <TabItem Header="Google Sheets">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="600">

                        <TextBlock Text="Google Sheets — Auto Backup" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                        <TextBlock Text="Automatically logs every completed session to a Google Spreadsheet."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <CheckBox Content="Enable Google Sheets Backup"
                                  IsChecked="{Binding SheetsEnabled}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,20"/>

                        <TextBlock Text="Spreadsheet ID" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBlock Text="The long string between /d/ and /edit in the sheet URL."
                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding SheetsSheetId, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Worksheet / Tab Name" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SheetsWorksheet, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="Service Account JSON Path" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBlock Text="Full path to your service_account.json file."
                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding SheetsServiceAccountPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================
                 TAB: Calendar
            ============================================================ -->
            <TabItem Header="Calendar">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="600">

                        <TextBlock Text="Google Calendar" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                        <TextBlock Text="The &quot;Add to Google Calendar&quot; button on the Newbie Shift screen creates a calendar event using a URL template. No API key required."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <CheckBox Content="Enable Google Calendar Integration"
                                  IsChecked="{Binding CalendarEnabled}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================
                 TAB: Payment
            ============================================================ -->
            <TabItem Header="Payment">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="600">

                        <TextBlock Text="Payment Simulation" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                        <TextBlock Text="These values are displayed during call grading as simulated payment data for the candidate to process."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Credit Card -->
                        <TextBlock Text="CREDIT CARD" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Card Type" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PaymentCcType, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Card Number" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PaymentCcNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Expiration" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PaymentCcExpiration, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CVV" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PaymentCcCvv, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,0,0,24"/>

                        <!-- EFT / Bank -->
                        <TextBlock Text="EFT / BANK ACCOUNT" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Routing Number" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PaymentEftRouting, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Account Number" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PaymentEftAccount, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================
                 TAB: Call Types
            ============================================================ -->
            <TabItem Header="Call Types">
                <lte:LookupTableEditorControl
                    Items="{Binding CallTypes}"
                    SelectedItem="{Binding SelectedCallType, Mode=TwoWay}"
                    AddCommand="{Binding AddCallTypeCommand}"
                    RemoveCommand="{Binding RemoveCallTypeCommand}"
                    MoveUpCommand="{Binding MoveCallTypeUpCommand}"
                    MoveDownCommand="{Binding MoveCallTypeDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <TextBlock Text="Category" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding CategoryOptions}"
                                          SelectedItem="{Binding Category}"
                                          Margin="0,4,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- ============================================================
                 TAB: Shows
            ============================================================ -->
            <TabItem Header="Shows">
                <lte:LookupTableEditorControl
                    Items="{Binding Shows}"
                    SelectedItem="{Binding SelectedShow, Mode=TwoWay}"
                    AddCommand="{Binding AddShowCommand}"
                    RemoveCommand="{Binding RemoveShowCommand}"
                    MoveUpCommand="{Binding MoveShowUpCommand}"
                    MoveDownCommand="{Binding MoveShowDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Show Name" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="One-Time Amount ($)" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding OneTimeAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                 Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Monthly Amount ($)" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding MonthlyAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                 Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Gift Description" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding GiftDescription, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- ============================================================
                 TAB: Callers
            ============================================================ -->
            <TabItem Header="Callers">
                <TabItem.Resources>
                    <DataTemplate x:Key="DonorDetailTemplate">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="First Name" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Last Name" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Address" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,12"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="City" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="State" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="ZIP" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding ZipCode, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Phone" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,12"/>

                            <TextBlock Text="Email" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,16"/>

                            <CheckBox Content="Enabled"
                                      IsChecked="{Binding IsEnabled}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabItem.Resources>

                <TabControl>
                    <TabItem Header="New Donors">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.NewDonors,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedNewDonor, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddNewDonorCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveNewDonorCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveNewDonorUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveNewDonorDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DetailTemplate="{StaticResource DonorDetailTemplate}"/>
                    </TabItem>

                    <TabItem Header="Existing Members">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.ExistingMembers,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedExistingMember, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddExistingMemberCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveExistingMemberCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveExistingMemberUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveExistingMemberDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DetailTemplate="{StaticResource DonorDetailTemplate}"/>
                    </TabItem>

                    <TabItem Header="Increase Sustaining">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.IncreaseSustaining,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedIncreaseSustaining, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddIncreaseSustainingCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveIncreaseSustainingCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveIncreaseSustainingUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveIncreaseSustainingDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DetailTemplate="{StaticResource DonorDetailTemplate}"/>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ============================================================
                 TAB: Sup Reasons
            ============================================================ -->
            <TabItem Header="Sup Reasons">
                <lte:LookupTableEditorControl
                    Items="{Binding SupervisorReasons}"
                    SelectedItem="{Binding SelectedSupervisorReason, Mode=TwoWay}"
                    AddCommand="{Binding AddSupervisorReasonCommand}"
                    RemoveCommand="{Binding RemoveSupervisorReasonCommand}"
                    MoveUpCommand="{Binding MoveSupervisorReasonUpCommand}"
                    MoveDownCommand="{Binding MoveSupervisorReasonDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- ============================================================
                 TAB: Fail Reasons
            ============================================================ -->
            <TabItem Header="Fail Reasons">
                <lte:LookupTableEditorControl
                    Items="{Binding FailReasons}"
                    SelectedItem="{Binding SelectedFailReason, Mode=TwoWay}"
                    AddCommand="{Binding AddFailReasonCommand}"
                    RemoveCommand="{Binding RemoveFailReasonCommand}"
                    MoveUpCommand="{Binding MoveFailReasonUpCommand}"
                    MoveDownCommand="{Binding MoveFailReasonDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Is 'Other' (shows a required text field during grading)"
                                          IsChecked="{Binding IsOther}"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="Applies to Calls"
                                          IsChecked="{Binding AppliesToCalls}"
                                          Margin="0,0,0,4"/>

                                <CheckBox Content="Applies to Supervisor Transfers"
                                          IsChecked="{Binding AppliesToSupTransfers}"
                                          Margin="0,0,0,16"/>

                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- ============================================================
                 TAB: Coaching
            ============================================================ -->
            <TabItem Header="Coaching">
                <lte:LookupTableEditorControl
                    Items="{Binding CoachingCategories}"
                    SelectedItem="{Binding SelectedCoachingCategory, Mode=TwoWay}"
                    AddCommand="{Binding AddCoachingCategoryCommand}"
                    RemoveCommand="{Binding RemoveCoachingCategoryCommand}"
                    MoveUpCommand="{Binding MoveCoachingCategoryUpCommand}"
                    MoveDownCommand="{Binding MoveCoachingCategoryDownCommand}">
                    <lte:LookupTableEditorControl.DetailTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Label" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <CheckBox Content="Is 'Other' (shows coaching notes field during grading)"
                                          IsChecked="{Binding IsOther}"
                                          Margin="0,0,0,8"/>

                                <CheckBox Content="Applies to Calls"
                                          IsChecked="{Binding AppliesToCalls}"
                                          Margin="0,0,0,4"/>

                                <CheckBox Content="Applies to Supervisor Transfers"
                                          IsChecked="{Binding AppliesToSupTransfers}"
                                          Margin="0,0,0,12"/>

                                <Separator Margin="0,4,0,12"/>

                                <TextBlock Text="Sub-Items" Style="{StaticResource H3}" Margin="0,0,0,8"/>
                                <TextBlock Text="Sub-items appear as checkboxes under this category during grading."
                                           Style="{StaticResource Muted}" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ Add Sub-Item"
                                            Command="{Binding AddSubItemCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,5" Margin="0,0,6,0"/>
                                    <Button Content="Remove"
                                            Command="{Binding RemoveSubItemCommand}"
                                            CommandParameter="{Binding SelectedSubItem}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="10,5" Margin="0,0,6,0"/>
                                    <Button Content="&#x2191;"
                                            Command="{Binding MoveSubItemUpCommand}"
                                            CommandParameter="{Binding SelectedSubItem}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,5" Margin="0,0,4,0"/>
                                    <Button Content="&#x2193;"
                                            Command="{Binding MoveSubItemDownCommand}"
                                            CommandParameter="{Binding SelectedSubItem}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,5"/>
                                </StackPanel>

                                <ListBox ItemsSource="{Binding SubItems}"
                                         SelectedItem="{Binding SelectedSubItem, Mode=TwoWay}"
                                         MinHeight="72" MaxHeight="150"
                                         Background="{StaticResource SurfaceBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"
                                         Margin="0,0,0,8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayLabel}" Padding="4,2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource NavSelectedBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <StackPanel Visibility="{Binding SelectedSubItem,
                                                        Converter={StaticResource NullToVisibility}}">
                                    <TextBlock Text="Sub-Item Label" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding SelectedSubItem.Label,
                                                   UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,12"/>
                                </StackPanel>

                                <Separator Margin="0,4,0,12"/>
                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding IsEnabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </lte:LookupTableEditorControl.DetailTemplate>
                </lte:LookupTableEditorControl>
            </TabItem>

            <!-- ============================================================
                 TAB: Discord
            ============================================================ -->
            <TabItem Header="Discord">
                <TabControl>

                    <!-- Sub-tab: Templates -->
                    <TabItem Header="Message Templates">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.DiscordTemplates,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedDiscordTemplate, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddDiscordTemplateCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveDiscordTemplateCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveDiscordTemplateUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveDiscordTemplateDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <lte:LookupTableEditorControl.DetailTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Trigger / Name" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                        <TextBlock Text="A short label for this template (e.g. Pass, Fail, Sup Transfer)"
                                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding Trigger, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,16"/>

                                        <TextBlock Text="Message" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 MinHeight="100"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Margin="0,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </lte:LookupTableEditorControl.DetailTemplate>
                        </lte:LookupTableEditorControl>
                    </TabItem>

                    <!-- Sub-tab: Screenshots -->
                    <TabItem Header="Screenshots">
                        <lte:LookupTableEditorControl
                            Items="{Binding DataContext.DiscordScreenshots,
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedItem="{Binding DataContext.SelectedDiscordScreenshot, Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                            AddCommand="{Binding DataContext.AddDiscordScreenshotCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            RemoveCommand="{Binding DataContext.RemoveDiscordScreenshotCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveUpCommand="{Binding DataContext.MoveDiscordScreenshotUpCommand,
                                           RelativeSource={RelativeSource AncestorType=UserControl}}"
                            MoveDownCommand="{Binding DataContext.MoveDiscordScreenshotDownCommand,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <lte:LookupTableEditorControl.DetailTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="Title" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,16"/>

                                        <TextBlock Text="Image URL" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Full URL to the image (https://...)"
                                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </lte:LookupTableEditorControl.DetailTemplate>
                        </lte:LookupTableEditorControl>
                    </TabItem>

                </TabControl>
            </TabItem>

        </TabControl>

        <!-- ================================================================
             FOOTER ACTIONS
        ================================================================ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="&#x2190; Back"
                    Command="{Binding NavigateBackCommand}"
                    Style="{StaticResource GhostButton}"
                    Padding="16,10"/>

            <TextBlock Grid.Column="1"
                       Text="&#x25CF; Unsaved changes"
                       Foreground="{StaticResource WarningBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Visibility="{Binding IsDirty,
                                   Converter={StaticResource BoolToVisibility}}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Style="{StaticResource DangerButton}"
                        Padding="16,10" Margin="0,0,8,0"/>

                <Button Content="Save Settings"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="24,10"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
