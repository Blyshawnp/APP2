<UserControl x:Class="MTS.UI.Views.History.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:HistoryViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="1040">

                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Session History" Style="{StaticResource H1}" Margin="0,0,0,4"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Clear All History"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ClearAllHistoryCommand}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Stats row -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Grid.Column="0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalSessions}" Style="{StaticResource H2}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Grid.Column="2">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalPass}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource PassBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Passed" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Grid.Column="4">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalFail}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource FailBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Failed" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Grid.Column="6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalNcNs}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="NC/NS" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Grid.Column="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalIncomplete}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Incomplete" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Grid.Column="10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource H2}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource PassBrush}">
                                <Run Text="{Binding Stats.PassRate, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                            <TextBlock Text="Pass Rate" Style="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Search bar -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Search by candidate name..."/>
                    <Button Grid.Column="2" Content="Search"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SearchCommand}"/>
                </Grid>

                <!-- Empty state -->
                <TextBlock Text="No sessions recorded yet."
                           Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,48"
                           Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}"/>

                <!-- Sessions table -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DATE"      Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="1" Text="CANDIDATE" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="2" Text="TESTER"    Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="3" Text="STATUS"    Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="4" Text=""           Style="{StaticResource SectionHeader}"/>
                        </Grid>

                        <Separator Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding Sessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd h:mm tt'}"
                                                   Style="{StaticResource Muted}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CandidateName}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TesterName}"
                                                   Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Status}"
                                                   Foreground="{Binding Status, Converter={StaticResource SessionStatusToBrush}}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Button Content="Back to Dashboard"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Left"/>
        </Border>
    </Grid>
</UserControl>