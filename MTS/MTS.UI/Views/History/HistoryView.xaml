<UserControl x:Class="MTS.UI.Views.History.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:HistoryViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="960">

                <!-- Header -->
                <TextBlock Text="History" Style="{StaticResource H1}" Margin="0,0,0,4"/>
                <TextBlock Text="All completed sessions." Style="{StaticResource Muted}" Margin="0,0,0,24"/>

                <!-- Stats row -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Sessions -->
                    <Border Style="{StaticResource Card}" Grid.Column="0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalSessions}" Style="{StaticResource H2}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Total" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Pass -->
                    <Border Style="{StaticResource Card}" Grid.Column="2">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalPass}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource PassBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Pass" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Fail -->
                    <Border Style="{StaticResource Card}" Grid.Column="4">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalFail}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource FailBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Fail" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Pass Rate -->
                    <Border Style="{StaticResource Card}" Grid.Column="6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource H2}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}">
                                <Run Text="{Binding Stats.PassRate, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                            <TextBlock Text="Pass Rate" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- NC/NS -->
                    <Border Style="{StaticResource Card}" Grid.Column="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Stats.TotalNcNs}" Style="{StaticResource H2}"
                                       Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="NC/NS" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- NC/NS Rate -->
                    <Border Style="{StaticResource Card}" Grid.Column="10">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource H2}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource WarningBrush}">
                                <Run Text="{Binding Stats.NcNsRate, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                            <TextBlock Text="NC/NS Rate" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Search + Clear All -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Search by candidate or tester name…"/>
                    <Button Grid.Column="2" Content="Search"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SearchCommand}"/>
                    <Button Grid.Column="4" Content="Clear All History"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ClearAllHistoryCommand}"/>
                </Grid>

                <!-- Empty state -->
                <TextBlock Text="No sessions recorded yet."
                           Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,48"
                           Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}"/>

                <!-- Sessions table -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <!-- Table header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DATE"       Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="1" Text="CANDIDATE"  Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="2" Text="TESTER"     Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="3" Text="STATUS"     Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Column="4" Text=""            Style="{StaticResource SectionHeader}"/>
                        </Grid>

                        <Separator Margin="0,0,0,8"/>

                        <!-- Session rows -->
                        <ItemsControl ItemsSource="{Binding Sessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding CreatedAt, StringFormat='MMM d, yyyy'}"
                                                   Style="{StaticResource Muted}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CandidateName}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TesterName}"
                                                   Style="{StaticResource Muted}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Status}"
                                                   Foreground="{Binding Status, Converter={StaticResource SessionStatusToBrush}}"/>
                                        <TextBlock Grid.Column="4" Text="NC/NS"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutoFailReason}" Value="NcNs">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Button Content="← Back to Dashboard"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Left"/>
        </Border>
    </Grid>
</UserControl>
