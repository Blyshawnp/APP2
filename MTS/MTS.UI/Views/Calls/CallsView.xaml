<UserControl x:Class="MTS.UI.Views.Calls.CallsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels.Calls"
             xmlns:cg="clr-namespace:MTS.UI.Controls.CoachingGrid"
             xmlns:fg="clr-namespace:MTS.UI.Controls.FailReasonsGrid"
             xmlns:wb="clr-namespace:MTS.UI.Controls.WarningBanner"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:CallsViewModel}">

    <UserControl.Resources>
        <DataTemplate x:Key="CallCardTemplate" DataType="{x:Type vm:CallRecordViewModel}">
            <StackPanel>

                <!-- ============================================================
                     ROW 1: Split — Call Setup (left) | Scenario (right)
                ============================================================ -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Call Setup -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,18">
                        <StackPanel>
                            <TextBlock Text="CALL SETUP" Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,14"/>

                            <!-- Validation errors -->
                            <wb:WarningBannerControl Warnings="{Binding ValidationErrors}"
                                                     Margin="0,0,0,10"/>

                            <!-- Card header: submitted badge -->
                            <Border Background="{StaticResource PassSurfaceBrush}"
                                    BorderBrush="{StaticResource PassBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="10,3"
                                    HorizontalAlignment="Right" Margin="0,0,0,10"
                                    Visibility="{Binding IsCompleted,
                                                 Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Submitted" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource PassBrush}"/>
                            </Border>

                            <!-- Call Type + Show -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Call Type" Style="{StaticResource Label}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableCallTypes}"
                                              SelectedItem="{Binding SelectedCallType, Mode=TwoWay}"
                                              DisplayMemberPath="Label"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Show" Style="{StaticResource Label}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableShows}"
                                              SelectedItem="{Binding SelectedShow, Mode=TwoWay}"
                                              DisplayMemberPath="Name"/>
                                </StackPanel>
                            </Grid>

                            <!-- Caller -->
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Caller" Style="{StaticResource Label}"
                                           Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AvailableCallers}"
                                          SelectedItem="{Binding SelectedCaller, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"/>
                            </StackPanel>

                            <!-- Donation -->
                            <StackPanel>
                                <TextBlock Text="Donation Amount ($)" Style="{StaticResource Label}"
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding DonationAmount, Mode=TwoWay,
                                                StringFormat='{}{0:F2}',
                                                UpdateSourceTrigger=LostFocus}"
                                         MaxWidth="140" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT: Scenario -->
                    <Border Grid.Column="2"
                            Background="{StaticResource ScenarioBrush}"
                            BorderBrush="{StaticResource ScenarioBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="20,18">
                        <StackPanel>
                            <TextBlock Text="SCENARIO"
                                       Style="{StaticResource SectionHeader}"
                                       Foreground="{StaticResource ScenarioBorderBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding ScenarioText}"
                                       TextWrapping="Wrap" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       LineHeight="20"
                                       Margin="0,0,0,16"/>

                            <Separator Background="{StaticResource ScenarioBorderBrush}"
                                       Opacity="0.25" Margin="0,0,0,12"/>

                            <TextBlock Text="FLAGS"
                                       Style="{StaticResource SectionHeader}"
                                       Foreground="{StaticResource ScenarioBorderBrush}"
                                       Margin="0,0,0,8"/>
                            <StackPanel>
                                <TextBlock Visibility="{Binding ScenarioFlags.HasPhone,
                                                         Converter={StaticResource BoolToVisibility}}"
                                           Text="&#x1F4DE;  Phone" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Visibility="{Binding ScenarioFlags.HasSms,
                                                         Converter={StaticResource BoolToVisibility}}"
                                           Text="&#x1F4F1;  SMS" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Visibility="{Binding ScenarioFlags.HasEnews,
                                                         Converter={StaticResource BoolToVisibility}}"
                                           Text="&#x1F4E7;  eNews" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Visibility="{Binding ScenarioFlags.HasShipping,
                                                         Converter={StaticResource BoolToVisibility}}"
                                           Text="&#x1F4E6;  Shipping" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Visibility="{Binding ScenarioFlags.HasCcFee,
                                                         Converter={StaticResource BoolToVisibility}}"
                                           Text="&#x1F4B3;  CC Fee" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                            </StackPanel>

                            <Button Content="&#x21BB; Regenerate"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding RegenerateScenarioCommand}"
                                    Padding="8,4" FontSize="11"
                                    HorizontalAlignment="Left"
                                    Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ============================================================
                     ROW 2: Payment Simulation
                ============================================================ -->
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="PAYMENT SIMULATION" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- CC card -->
                            <Border Grid.Column="0"
                                    Background="{StaticResource SurfaceElevatedBrush}"
                                    CornerRadius="6" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4B3;  AMERICAN EXPRESS"
                                               FontWeight="Bold" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding PaymentSim.CardNumber}"
                                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Margin="0,0,20,0">
                                            <TextBlock Text="EXP" Style="{StaticResource Muted}"
                                                       FontSize="10" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding PaymentSim.CardExpiry}"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="CID" Style="{StaticResource Muted}"
                                                       FontSize="10" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding PaymentSim.CardCvv}"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- EFT card -->
                            <Border Grid.Column="2"
                                    Background="{StaticResource SurfaceElevatedBrush}"
                                    CornerRadius="6" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="&#x1F3E6;  EFT / BANK DRAFT"
                                               FontWeight="Bold" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Routing" Style="{StaticResource Muted}"
                                               FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding PaymentSim.BankRouting}"
                                               FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="Account" Style="{StaticResource Muted}"
                                               FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding PaymentSim.BankAccount}"
                                               FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 3: Caller Demographics
                ============================================================ -->
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="CALLER DEMOGRAPHICS" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Address" Style="{StaticResource Label}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedCaller.FullAddress}"
                                           Style="{StaticResource Muted}" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Phone" Style="{StaticResource Label}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedCaller.Phone}"
                                           Style="{StaticResource Muted}" FontSize="12"/>
                                <TextBlock Text="Email" Style="{StaticResource Label}"
                                           Margin="0,8,0,2"/>
                                <TextBlock Text="{Binding SelectedCaller.Email}"
                                           Style="{StaticResource Muted}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 4: Call Result
                ============================================================ -->
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="CALL RESULT" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="&#x2713;  PASS"
                                    Command="{Binding SelectPassCommand}"
                                    Padding="0,14" FontSize="16" FontWeight="Bold"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource SuccessButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPassSelected}"
                                                         Value="True">
                                                <Setter Property="BorderBrush" Value="White"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPassSelected}"
                                                         Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2"
                                    Content="&#x2717;  FAIL"
                                    Command="{Binding SelectFailCommand}"
                                    Padding="0,14" FontSize="16" FontWeight="Bold"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button"
                                           BasedOn="{StaticResource DangerButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFailSelected}"
                                                         Value="True">
                                                <Setter Property="BorderBrush" Value="White"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFailSelected}"
                                                         Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 5: Coaching (shown after result selected)
                ============================================================ -->
                <Border Style="{StaticResource Card}" Padding="20,18" Margin="0,0,0,12"
                        Visibility="{Binding Result, Converter={StaticResource NullToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="COACHING GIVEN" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="One or more may be selected"
                                   Style="{StaticResource Muted}" FontSize="12"
                                   Margin="0,0,0,12"/>
                        <cg:CoachingGrid Items="{Binding CoachingItems}"
                                         ShowCoachingWarning="{Binding HasCoachingSkippedWarning}"/>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 6: Fail Reasons (Fail only)
                ============================================================ -->
                <Border Visibility="{Binding ShowFailSection,
                                     Converter={StaticResource BoolToVisibility}}"
                        Background="{StaticResource FailSurfaceBrush}"
                        BorderBrush="{StaticResource FailBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,18"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="&#x26A0; FAIL REASONS"
                                   Style="{StaticResource SectionHeader}"
                                   Foreground="{StaticResource FailBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="One or more may be selected"
                                   Style="{StaticResource Muted}" FontSize="12"
                                   Margin="0,0,0,12"/>
                        <fg:FailReasonsGrid Items="{Binding FailItems}"
                                            ShowRequiredError="{Binding HasOtherFail}"/>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 7: Submit
                ============================================================ -->
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.SubmitCallCommand,
                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Content="Submit Call"
                        HorizontalAlignment="Left"
                        Padding="28,11"
                        Margin="0,0,0,8"
                        Visibility="{Binding Result,
                                     Converter={StaticResource NullToVisibility}}"/>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================================================================
             SCROLLABLE CONTENT
        ================================================================ -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="1060">

                <!-- Header -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Calls" Style="{StaticResource H1}"/>
                        <TextBlock Text="Grade each mock call. Calls 1 and 2 are always required."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="180">
                        <TextBlock Text="{Binding ProgressPercent, StringFormat='Progress: {0}%'}"
                                   Style="{StaticResource Label}" HorizontalAlignment="Right"
                                   Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="8"
                                     Background="{StaticResource SurfaceElevatedBrush}"
                                     Foreground="{StaticResource AccentBrush}"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Grid>

                <!-- Step tabs -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                    <!-- Call 1 -->
                    <Border CornerRadius="16" Padding="16,6" Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{StaticResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveCallNumber}" Value="1">
                                        <Setter Property="Background"
                                                Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCall1Done}" Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource PassSurfaceBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Call 1"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveCallNumber}" Value="1">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCall1Done}" Value="True">
                                            <Setter Property="Text"       Value="&#x2713; Call 1"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource PassBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <TextBlock Text="&#x203A;"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <!-- Call 2 -->
                    <Border CornerRadius="16" Padding="16,6" Margin="0,0,6,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{StaticResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveCallNumber}" Value="2">
                                        <Setter Property="Background"
                                                Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCall2Done}" Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource PassSurfaceBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Call 2"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveCallNumber}" Value="2">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCall2Done}" Value="True">
                                            <Setter Property="Text"       Value="&#x2713; Call 2"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource PassBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <TextBlock Text="&#x203A;"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Visibility="{Binding IsCall3Visible,
                                            Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Call 3 (only when needed) -->
                    <Border CornerRadius="16" Padding="16,6"
                            Visibility="{Binding IsCall3Visible,
                                         Converter={StaticResource BoolToVisibility}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="{StaticResource SurfaceElevatedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveCallNumber}" Value="3">
                                        <Setter Property="Background"
                                                Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCall3Done}" Value="True">
                                        <Setter Property="Background"
                                                Value="{StaticResource PassSurfaceBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Call 3"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveCallNumber}" Value="3">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCall3Done}" Value="True">
                                            <Setter Property="Text"       Value="&#x2713; Call 3"/>
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource PassBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Page-level warnings -->
                <wb:WarningBannerControl Warnings="{Binding PageWarnings}" Margin="0,0,0,16"/>

                <!-- Active call card -->
                <ContentPresenter Content="{Binding ActiveCall}"
                                  ContentTemplate="{StaticResource CallCardTemplate}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ================================================================
             FOOTER
        ================================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x2190; Back"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BackCommand}"/>

                <Button Grid.Column="2" Content="&#x26A0; Stopped Responding"
                        Style="{StaticResource WarningButton}"
                        Command="{Binding StoppedRespondingCommand}"/>

                <Button Grid.Column="4" Content="Tech Issue"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding TechIssueCommand}"/>

                <Button Grid.Column="6" Content="Continue &#x2192;"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ProceedCommand}"
                        IsEnabled="{Binding CanProceed}"/>
            </Grid>
        </Border>

    </Grid>

</UserControl>
