<UserControl x:Class="MTS.UI.Views.NewbieShift.NewbieShiftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             xmlns:enums="clr-namespace:MTS.Core.Enums;assembly=MTS.Core"
             d:DataContext="{d:DesignInstance Type=vm:NewbieShiftViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="600">

                <TextBlock Text="Newbie Shift" Style="{StaticResource H1}" Margin="0,0,0,4"/>
                <TextBlock Text="Record the candidate's first newbie shift so it can be added to their calendar."
                           Style="{StaticResource Muted}" Margin="0,0,0,24"/>

                <!-- Shift details card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="SHIFT DETAILS" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Date" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding ShiftDate}"
                                            Background="{StaticResource InputBackgroundBrush}"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderBrush="{StaticResource InputBorderBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Timezone" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                <ComboBox SelectedItem="{Binding Timezone}">
                                    <enums:AppTimezone>Eastern</enums:AppTimezone>
                                    <enums:AppTimezone>Central</enums:AppTimezone>
                                    <enums:AppTimezone>Mountain</enums:AppTimezone>
                                    <enums:AppTimezone>Pacific</enums:AppTimezone>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Time -->
                        <TextBlock Text="Time" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding ShiftHour, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" TextAlignment="Center"/>
                            <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0" FontSize="16"/>
                            <TextBox Text="{Binding ShiftMinute, UpdateSourceTrigger=PropertyChanged, StringFormat=D2}"
                                     Width="50" TextAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                <RadioButton Content="AM" IsChecked="{Binding IsAm}" Margin="0,0,12,0"/>
                                <RadioButton Content="PM" IsChecked="{Binding IsAm, Converter={StaticResource InverseBoolToVisibility}}" Margin="0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Calendar event preview -->
                <Border Background="{StaticResource ScenarioBrush}"
                        BorderBrush="{StaticResource ScenarioBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="CALENDAR EVENT PREVIEW" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CalendarEventTitle}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource ScenarioBorderBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Back"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BackCommand}"/>

                <Button Grid.Column="2" Content="Skip (No Shift)"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding DiscardCommand}"/>

                <Button Grid.Column="4" Content="Save &amp; Continue →"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveAndContinueCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
