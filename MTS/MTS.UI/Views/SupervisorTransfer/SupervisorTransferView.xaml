<UserControl x:Class="MTS.UI.Views.SupervisorTransfer.SupervisorTransferView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels.SupervisorTransfer"
             xmlns:cg="clr-namespace:MTS.UI.Controls.CoachingGrid"
             xmlns:fg="clr-namespace:MTS.UI.Controls.FailReasonsGrid"
             xmlns:wb="clr-namespace:MTS.UI.Controls.WarningBanner"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SupervisorTransferViewModel}">

    <UserControl.Resources>
        <!-- Reusable style for disabling completed transfers -->
        <Style x:Key="CompletedGridStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity"   Value="0.6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompletedCardStyle" TargetType="Border" BasedOn="{StaticResource Card}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity"   Value="0.6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompletedBorderStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity"   Value="0.6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompletedButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity"   Value="0.6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TransferCardTemplate" DataType="{x:Type vm:TransferRecordViewModel}">
            <StackPanel>

                <!-- Card header: transfer number + submitted badge -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="15"
                                Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="{Binding TransferNumber}" FontWeight="Bold"
                                       FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TransferNumber, StringFormat='Transfer {0}'}"
                                   Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource PassSurfaceBrush}"
                            BorderBrush="{StaticResource PassBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="10,3"
                            VerticalAlignment="Center">
                        <TextBlock Text="Submitted" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource PassBrush}"/>
                    </Border>
                </Grid>

                <!-- Validation errors -->
                <wb:WarningBannerControl Warnings="{Binding ValidationErrors}" Margin="0,0,0,12"/>

                <!-- ============================================================
                     ROW 1: Split — Call Setup (left) | Scenario (right)
                ============================================================ -->
                <Grid Margin="0,0,0,12" Style="{StaticResource CompletedGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Call Setup -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,18">
                        <StackPanel>
                            <TextBlock Text="CALL SETUP" Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,14"/>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Caller" Style="{StaticResource Label}"
                                           Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AllDonors}"
                                          SelectedItem="{Binding SelectedCaller, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Show" Style="{StaticResource Label}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableShows}"
                                              SelectedItem="{Binding SelectedShow, Mode=TwoWay}"
                                              DisplayMemberPath="Name"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Transfer Reason" Style="{StaticResource Label}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableReasons}"
                                              SelectedItem="{Binding SelectedReason, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT: Scenario -->
                    <Border Grid.Column="2"
                            Background="{StaticResource ScenarioBrush}"
                            BorderBrush="{StaticResource ScenarioBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="20,18">
                        <StackPanel>
                            <TextBlock Text="SCENARIO"
                                       Style="{StaticResource SectionHeader}"
                                       Foreground="{StaticResource ScenarioBorderBrush}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding ScenarioText}"
                                       TextWrapping="Wrap" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       LineHeight="20"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ============================================================
                     ROW 2: Caller Demographics
                ============================================================ -->
                <Border Padding="20,18" Margin="0,0,0,12" Style="{StaticResource CompletedCardStyle}">
                    <StackPanel>
                        <TextBlock Text="CALLER INFO" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Address" Style="{StaticResource Label}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedCaller.FullAddress}"
                                           Style="{StaticResource Muted}" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Phone" Style="{StaticResource Label}"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedCaller.Phone}"
                                           Style="{StaticResource Muted}" FontSize="12"/>
                                <TextBlock Text="Email" Style="{StaticResource Label}"
                                           Margin="0,8,0,2"/>
                                <TextBlock Text="{Binding SelectedCaller.Email}"
                                           Style="{StaticResource Muted}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 3: Transfer Result
                ============================================================ -->
                <Border Padding="20,18" Margin="0,0,0,12" Style="{StaticResource CompletedCardStyle}">
                    <StackPanel>
                        <TextBlock Text="TRANSFER RESULT" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="&#x2713;  PASS"
                                    Command="{Binding SelectPassCommand}"
                                    Padding="0,14" FontSize="16" FontWeight="Bold"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPassSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="White"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPassSelected}" Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2"
                                    Content="&#x2717;  FAIL"
                                    Command="{Binding SelectFailCommand}"
                                    Padding="0,14" FontSize="16" FontWeight="Bold"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFailSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="White"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFailSelected}" Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 4: Coaching (shown after result selected)
                ============================================================ -->
                <Border Padding="20,18" Margin="0,0,0,12"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}"
                        Style="{StaticResource CompletedCardStyle}">
                    <StackPanel>
                        <TextBlock Text="COACHING GIVEN" Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="One or more may be selected"
                                   Style="{StaticResource Muted}" FontSize="12"
                                   Margin="0,0,0,12"/>
                        <cg:CoachingGrid Items="{Binding CoachingItems}"
                                         ShowCoachingWarning="{Binding HasCoachingSkippedWarning}"/>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 5: Fail Reasons (Fail only)
                ============================================================ -->
                <Border Visibility="{Binding ShowFollowUpSection, Converter={StaticResource BoolToVisibility}}"
                        Background="{StaticResource FailSurfaceBrush}"
                        BorderBrush="{StaticResource FailBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,18"
                        Margin="0,0,0,12"
                        Style="{StaticResource CompletedBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="&#x26A0; FAIL REASONS" Style="{StaticResource SectionHeader}"
                                   Foreground="{StaticResource FailBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="One or more may be selected"
                                   Style="{StaticResource Muted}" FontSize="12"
                                   Margin="0,0,0,12"/>
                        <fg:FailReasonsGrid Items="{Binding FailItems}"
                                            ShowRequiredError="{Binding HasOtherFail}"/>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     ROW 6: Submit
                ============================================================ -->
                <Button Command="{Binding DataContext.SubmitTransferCommand,
                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Content="Submit Transfer"
                        HorizontalAlignment="Left"
                        Padding="24,11"
                        Margin="0,0,0,8"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}"
                        Style="{StaticResource CompletedButtonStyle}"/>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="1060">

                <!-- Header -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Supervisor Transfer" Style="{StaticResource H1}"/>
                        <TextBlock Text="Grade each transfer attempt. Transfer 2 appears only if Transfer 1 fails."
                                   Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="180">
                        <TextBlock Text="{Binding ProgressPercent, StringFormat='Progress: {0}%'}"
                                   Style="{StaticResource Label}" HorizontalAlignment="Right"
                                   Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="8"
                                     Background="{StaticResource SurfaceElevatedBrush}"
                                     Foreground="{StaticResource AccentBrush}"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Grid>

                <!-- Transfer phone banner -->
                <Border Background="{StaticResource AccentBrush}"
                        CornerRadius="8" Padding="16,12"
                        Margin="0,12,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE717;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="SUPERVISOR TRANSFER LINE"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="#B0C4FF"/>
                            <TextBlock Text="{Binding SupTransferPhoneNumber}"
                                       FontSize="22" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Discord Post section -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="DISCORD POST FOR STARS"
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource InputBorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="10,8">
                                <TextBlock Text="{Binding DiscordPostText}"
                                           TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Button Grid.Column="2" Content="Copy"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CopyDiscordPostCommand}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Page warnings -->
                <wb:WarningBannerControl Warnings="{Binding PageWarnings}" Margin="0,0,0,16"/>

                <!-- Transfer 1 -->
                <ContentPresenter Content="{Binding Transfer1}"
                                  ContentTemplate="{StaticResource TransferCardTemplate}"
                                  Margin="0,0,0,16"/>

                <!-- Transfer 2 (hidden until T1 fails) -->
                <ContentPresenter Content="{Binding Transfer2}"
                                  ContentTemplate="{StaticResource TransferCardTemplate}"
                                  Margin="0,0,0,16"
                                  Visibility="{Binding IsTransfer2Visible,
                                               Converter={StaticResource BoolToVisibility}}"/>

                <!-- Newbie shift notice -->
                <Border Visibility="{Binding RequiresNewbieShift, Converter={StaticResource BoolToVisibility}}"
                        Background="{StaticResource IncompleteSurfaceBrush}"
                        BorderBrush="{StaticResource IncompleteBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="&#x26A0; Newbie Shift Required"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource IncompleteBrush}"/>
                        <TextBlock Text="Both transfers failed. You will need to schedule a newbie shift before finishing the review."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="&#x2190; Back"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BackCommand}"/>

                <Button Grid.Column="2" Content="&#x26A0; Stopped Responding"
                        Style="{StaticResource WarningButton}"
                        Command="{Binding StoppedRespondingCommand}"/>

                <Button Grid.Column="4" Content="Tech Issue"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding TechIssueCommand}"/>

                <Button Grid.Column="6"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ProceedCommand}"
                        IsEnabled="{Binding CanProceed}"
                        Content="Continue &#x2192;"
                        Padding="24,10" FontSize="14"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>