<UserControl x:Class="MTS.UI.Views.Basics.BasicsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             xmlns:enums="clr-namespace:MTS.Core.Enums;assembly=MTS.Core"
             d:DataContext="{d:DesignInstance Type=vm:BasicsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="860">

            <!-- Page title -->
            <TextBlock Text="The Basics" Style="{StaticResource H1}" Margin="0,0,0,4"/>
            <TextBlock Text="Complete all pre-checks before starting the session."
                       Style="{StaticResource Muted}" Margin="0,0,0,24"/>

            <!-- Validation message -->
            <Border Background="{StaticResource FailSurfaceBrush}"
                    BorderBrush="{StaticResource FailBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8"
                    Margin="0,0,0,16"
                    Visibility="{Binding ValidationMessage, Converter={StaticResource EmptyStringToVisibility}}">
                <TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource FailBrush}"/>
            </Border>

            <!-- ============================================================
                 SESSION INFO
            ============================================================ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="SESSION INFO" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tester Name (read-only) -->
                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Tester Name" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding TesterName}" IsReadOnly="True" Opacity="0.6"/>
                        </StackPanel>

                        <!-- Candidate Name -->
                        <StackPanel Grid.Column="2" Grid.Row="0">
                            <TextBlock Text="Candidate Name *" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CandidateName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Pronouns -->
                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Pronouns" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="She/Her"
                                             IsChecked="{Binding Pronoun, Converter={StaticResource EnumEquality}, ConverterParameter={x:Static enums:Pronoun.She}}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="He/Him"
                                             IsChecked="{Binding Pronoun, Converter={StaticResource EnumEquality}, ConverterParameter={x:Static enums:Pronoun.He}}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="They/Them"
                                             IsChecked="{Binding Pronoun, Converter={StaticResource EnumEquality}, ConverterParameter={x:Static enums:Pronoun.They}}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Options -->
                        <StackPanel Grid.Column="2" Grid.Row="2" Orientation="Horizontal">
                            <CheckBox Content="Final Attempt" IsChecked="{Binding IsFinalAttempt}" Margin="0,0,24,0"/>
                            <CheckBox Content="Supervisor Only" IsChecked="{Binding IsSupervisorOnly}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============================================================
                 HEADSET + VPN  (side by side)
            ============================================================ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Headset -->
                <Border Style="{StaticResource Card}" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="HEADSET" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                        <TextBlock Text="Is the headset USB?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton Content="Yes"
                                         IsChecked="{Binding IsHeadsetUsb, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="No"
                                         IsChecked="{Binding IsHeadsetUsb, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                        </StackPanel>

                        <!-- Wrong headset warning -->
                        <Border Background="{StaticResource FailSurfaceBrush}"
                                BorderBrush="{StaticResource FailBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8,6"
                                Margin="0,0,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHeadsetUsb}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="⚠ Non-USB headset — session will AUTO-FAIL."
                                       Foreground="{StaticResource FailBrush}" FontSize="12"/>
                        </Border>

                        <TextBlock Text="Noise cancelling?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton Content="Yes"
                                         IsChecked="{Binding HasNoiseCancelling, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="No"
                                         IsChecked="{Binding HasNoiseCancelling, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                        </StackPanel>

                        <TextBlock Text="Headset brand / model" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding HeadsetBrand, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- VPN -->
                <Border Style="{StaticResource Card}" Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="VPN" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                        <TextBlock Text="Is VPN running?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton Content="Yes"
                                         IsChecked="{Binding HasVpn, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="No"
                                         IsChecked="{Binding HasVpn, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVpn}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Can they turn it off?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <RadioButton Content="Yes"
                                             IsChecked="{Binding CanTurnOffVpn, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="No"
                                             IsChecked="{Binding CanTurnOffVpn, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                            </StackPanel>

                            <!-- Auto-fail warning -->
                            <Border Background="{StaticResource FailSurfaceBrush}"
                                    BorderBrush="{StaticResource FailBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanTurnOffVpn}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="⚠ VPN cannot be disabled — session will AUTO-FAIL."
                                           Foreground="{StaticResource FailBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============================================================
                 BROWSER
            ============================================================ -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="BROWSER" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Chrome is default?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Yes"
                                             IsChecked="{Binding IsChromeDefault, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="No"
                                             IsChecked="{Binding IsChromeDefault, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Extensions off?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Yes"
                                             IsChecked="{Binding AreExtensionsOff, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="No"
                                             IsChecked="{Binding AreExtensionsOff, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Pop-ups allowed?" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Yes"
                                             IsChecked="{Binding ArePopUpsAllowed, Converter={StaticResource NullableBool}, ConverterParameter=true}"
                                             Margin="0,0,16,0"/>
                                <RadioButton Content="No"
                                             IsChecked="{Binding ArePopUpsAllowed, Converter={StaticResource NullableBool}, ConverterParameter=false}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Chrome not default warning -->
                    <Border Background="{StaticResource FailSurfaceBrush}"
                            BorderBrush="{StaticResource FailBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,6"
                            Margin="0,12,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChromeDefault}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="⚠ Chrome is not the default browser — session will AUTO-FAIL."
                                   Foreground="{StaticResource FailBrush}" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============================================================
                 FOOTER
            ============================================================ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Back"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding BackCommand}"/>

                <Button Grid.Column="2" Content="NC/NS"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding NcNsCommand}"/>

                <Button Grid.Column="4" Content="Not Ready"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding NotReadyCommand}"/>

                <Button Grid.Column="6" Content="⚠ Stopped Responding"
                        Style="{StaticResource WarningButton}"
                        Command="{Binding StoppedRespondingCommand}"/>

                <Button Grid.Column="8" Content="Continue →"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ContinueCommand}"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
