<UserControl x:Class="MTS.UI.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================================================================
             Header
        ================================================================ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Dashboard" Style="{StaticResource H1}"/>
            <TextBlock Text="Session overview and quick actions"
                       Style="{StaticResource Muted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ================================================================
             Stats row
        ================================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Total Sessions" Style="{StaticResource Label}"/>
                    <TextBlock Text="{Binding Stats.TotalSessions}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Pass -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Passed" Style="{StaticResource Label}"/>
                    <TextBlock Text="{Binding Stats.TotalPass}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource PassBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Fail -->
            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Failed" Style="{StaticResource Label}"/>
                    <TextBlock Text="{Binding Stats.TotalFail}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource FailBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Pass Rate -->
            <Border Grid.Column="6" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Pass Rate" Style="{StaticResource Label}"/>
                    <TextBlock Text="{Binding Stats.PassRate, StringFormat='{}{0}%'}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================================================================
             Action buttons
        ================================================================ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button Style="{StaticResource PrimaryButton}"
                    Command="{Binding StartSessionCommand}"
                    Content="Start New Session"
                    Padding="20,10" FontSize="14" Margin="0,0,12,0"/>

            <Button Style="{StaticResource SecondaryButton}"
                    Command="{Binding StartSupervisorOnlyCommand}"
                    Content="Supervisor Transfer Only"
                    Padding="20,10" FontSize="14" Margin="0,0,12,0"/>

            <Button Style="{StaticResource GhostButton}"
                    Command="{Binding OpenHistoryCommand}"
                    Content="View History"
                    Padding="20,10" FontSize="14"/>
        </StackPanel>

        <!-- ================================================================
             Recent Sessions Table
        ================================================================ -->
        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Recent Sessions" Style="{StaticResource H3}"/>

            <!-- Empty state -->
            <Border Grid.Row="2"
                    Style="{StaticResource Card}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="No sessions recorded yet. Start a new session to begin."
                           Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Padding="0,24"/>
            </Border>

            <!-- Session table -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding RecentSessions}"
                      Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      Background="{StaticResource SurfaceBrush}"
                      RowBackground="{StaticResource SurfaceBrush}"
                      AlternatingRowBackground="{StaticResource SurfaceElevatedBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      BorderThickness="1"
                      BorderBrush="{StaticResource BorderBrush}"
                      ColumnHeaderHeight="36"
                      RowHeight="38"
                      SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"   Value="{StaticResource SurfaceElevatedBrush}"/>
                        <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="Padding"      Value="12,0"/>
                        <Setter Property="FontSize"     Value="12"/>
                        <Setter Property="FontWeight"   Value="SemiBold"/>
                        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"     Value="12,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Candidate"
                                        Binding="{Binding CandidateName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Tester"
                                        Binding="{Binding TesterName}"
                                        Width="160"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}"
                                           Foreground="{Binding Status, Converter={StaticResource SessionStatusToBrush}}"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Calls Passed"
                                        Binding="{Binding CallsPassed}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding CreatedAt, StringFormat='MM/dd/yyyy'}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</UserControl>
