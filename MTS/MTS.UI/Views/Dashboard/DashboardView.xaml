<UserControl x:Class="MTS.UI.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28" MaxWidth="980">

            <!-- ================================================================
                 Header
            ================================================================ -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ACD logo badge -->
                <Border Grid.Column="0"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="4"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="ACD" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,0,3">
                        <Run Text="Welcome, " FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Run Text="{Binding WelcomeName}" FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Run Text="!" FontSize="28" FontWeight="Bold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                    </TextBlock>
                    <TextBlock Text="Mock Testing Suite — Certification"
                               Style="{StaticResource Muted}" FontSize="13"/>
                </StackPanel>
            </Grid>

            <!-- ================================================================
                 Stats row — 3 cards matching Electron
            ================================================================ -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL SESSIONS"
                                   Style="{StaticResource SectionHeader}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Stats.TotalSessions}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="PASS RATE"
                                   Style="{StaticResource SectionHeader}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PassBrush}"
                                   HorizontalAlignment="Center">
                            <Run Text="{Binding Stats.PassRate, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="NC/NS RATE"
                                   Style="{StaticResource SectionHeader}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource FailBrush}"
                                   HorizontalAlignment="Center">
                            <Run Text="{Binding Stats.NcNsRate, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================================================================
                 Action buttons — 3-column row
            ================================================================ -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartSessionCommand}"
                        Padding="0,16"
                        FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F680;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Start New Session" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding StartSupervisorOnlyCommand}"
                        Padding="0,16"
                        FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Supervisor Transfer Only" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenHistoryCommand}"
                        Padding="0,16"
                        FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Session History" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ================================================================
                 Recent Sessions
            ================================================================ -->
            <TextBlock Text="RECENT SESSIONS"
                       Style="{StaticResource SectionHeader}"
                       Margin="0,0,0,12"/>

            <!-- Empty state -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" Margin="0,32">
                    <TextBlock Text="No sessions recorded yet."
                               Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Text="Click Start New Session above to get started."
                               Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Sessions list -->
            <Border Style="{StaticResource Card}"
                    Padding="0"
                    Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding RecentSessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid Margin="20,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd h:mm tt'}"
                                               Style="{StaticResource Muted}" FontSize="12"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" Text=" • "
                                               Style="{StaticResource Muted}"
                                               VerticalAlignment="Center" FontSize="12"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CandidateName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Status badge -->
                                    <Border Grid.Column="3"
                                            CornerRadius="4" Padding="10,4"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource PassBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Fail">
                                                        <Setter Property="Background" Value="{StaticResource FailBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Incomplete">
                                                        <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Draft">
                                                        <Setter Property="Background" Value="{StaticResource TextMutedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
