<UserControl x:Class="MTS.UI.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28" MaxWidth="960">

            <!-- ================================================================
                 Header
            ================================================================ -->
            <TextBlock Margin="0,0,0,4">
                <Run Text="Welcome, " Style="{StaticResource H1}"/>
                <Run Text="{Binding WelcomeName}" FontSize="24" FontWeight="SemiBold"
                     Foreground="{StaticResource AccentBrush}"/>
                <Run Text="!" FontSize="24" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"/>
            </TextBlock>
            <TextBlock Text="Session overview and quick actions."
                       Style="{StaticResource Muted}" Margin="0,0,0,24"/>

            <!-- ================================================================
                 Stats row
            ================================================================ -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="TOTAL SESSIONS" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Stats.TotalSessions}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="PASS RATE" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PassBrush}">
                            <Run Text="{Binding Stats.PassRate}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="NC/NS RATE" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}">
                            <Run Text="{Binding Stats.NcNsRate}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================================================================
                 Action buttons
            ================================================================ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Button Style="{StaticResource SuccessButton}"
                        Command="{Binding StartSessionCommand}"
                        Padding="20,10" FontSize="14" Margin="0,0,12,0">
                    <TextBlock Text="&#x25B6;  Start New Session" Foreground="White"/>
                </Button>

                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding StartSupervisorOnlyCommand}"
                        Padding="20,10" FontSize="14" Margin="0,0,12,0">
                    <TextBlock Text="&#x1F4DE;  Supervisor Transfer Only"/>
                </Button>

                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding OpenHistoryCommand}"
                        Padding="20,10" FontSize="14">
                    <TextBlock Text="&#x1F4CB;  View History"/>
                </Button>
            </StackPanel>

            <!-- ================================================================
                 Recent Sessions
            ================================================================ -->
            <TextBlock Text="RECENT SESSIONS" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

            <!-- Empty state -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="No sessions recorded yet. Click Start New Session to begin."
                           Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Padding="0,24"/>
            </Border>

            <!-- Sessions table -->
            <Border Style="{StaticResource Card}"
                    Padding="0"
                    Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <!-- Column headers -->
                    <Grid Background="{StaticResource SurfaceElevatedBrush}"
                          Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="DATE"         Style="{StaticResource SectionHeader}"/>
                        <TextBlock Grid.Column="1" Text="CANDIDATE"    Style="{StaticResource SectionHeader}"/>
                        <TextBlock Grid.Column="2" Text="TESTER"       Style="{StaticResource SectionHeader}"/>
                        <TextBlock Grid.Column="3" Text="STATUS"       Style="{StaticResource SectionHeader}"/>
                        <TextBlock Grid.Column="4" Text="CALLS"        Style="{StaticResource SectionHeader}"/>
                        <TextBlock Grid.Column="5" Text="SUPS"         Style="{StaticResource SectionHeader}"/>
                    </Grid>
                    <Separator Margin="0"/>

                    <ItemsControl ItemsSource="{Binding RecentSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding CreatedAt, StringFormat='MMM d, yyyy'}"
                                               Style="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CandidateName}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TesterName}"
                                               Style="{StaticResource Muted}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Status}"
                                               Foreground="{Binding Status, Converter={StaticResource SessionStatusToBrush}}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="4" Text="{Binding CallsPassed}"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource PassBrush}"/>
                                    <TextBlock Grid.Column="5" Text="{Binding SupsPassed}"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
