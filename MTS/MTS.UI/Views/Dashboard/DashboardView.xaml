<UserControl x:Class="MTS.UI.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48,36" MaxWidth="680">

            <!-- ================================================================
                 Header — ACD badge + welcome
            ================================================================ -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                <Border Background="{StaticResource AccentBrush}"
                        CornerRadius="8" Padding="18,8"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                    <TextBlock Text="A C D" FontSize="15" FontWeight="Bold"
                               Foreground="White"/>
                </Border>
                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4">
                    <Run Text="Welcome, " FontSize="28" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Run Text="{Binding WelcomeName}" FontSize="28" FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}"/>
                    <Run Text="!" FontSize="28" FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
                </TextBlock>
                <TextBlock Text="Mock Testing Suite"
                           Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" FontSize="13"/>
            </StackPanel>

            <!-- ================================================================
                 Stats row — 3 cards matching Electron
            ================================================================ -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Stats.TotalSessions}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="TOTAL SESSIONS"
                                   Style="{StaticResource SectionHeader}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource PassBrush}"
                                   HorizontalAlignment="Center">
                            <Run Text="{Binding Stats.PassRate, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                        <TextBlock Text="PASS RATE"
                                   Style="{StaticResource SectionHeader}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Stats.TotalNcNs}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="NC / NS"
                                   Style="{StaticResource SectionHeader}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ================================================================
                 3 full-width action buttons
            ================================================================ -->
            <StackPanel Margin="0,0,0,40">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartSessionCommand}"
                        Padding="24,16" Margin="0,0,0,12"
                        HorizontalAlignment="Stretch"
                        FontSize="15" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F680;" Margin="0,0,10,0" FontSize="15"
                                   VerticalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="Start New Session" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SuccessButton}"
                        Command="{Binding StartSupervisorOnlyCommand}"
                        Padding="24,16" Margin="0,0,0,12"
                        HorizontalAlignment="Stretch"
                        FontSize="15" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4DE;" Margin="0,0,10,0" FontSize="15"
                                   VerticalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="Supervisor Transfer Only" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenHistoryCommand}"
                        Padding="24,16"
                        HorizontalAlignment="Stretch"
                        FontSize="15" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4CB;" Margin="0,0,10,0" FontSize="15"
                                   VerticalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="Session History" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- ================================================================
                 Recent Sessions
            ================================================================ -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="RECENT SESSIONS"
                           Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding OpenHistoryCommand}"
                        Padding="10,5" FontSize="12">
                    <TextBlock Text="View all &#x2192;"/>
                </Button>
            </Grid>

            <!-- Empty state -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" Margin="0,28">
                    <TextBlock Text="&#x1F4CB;" FontSize="34" HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="No sessions recorded yet."
                               Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" FontSize="14" Margin="0,0,0,4"/>
                    <TextBlock Text="Click Start New Session above to get started."
                               Style="{StaticResource Muted}"
                               HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Sessions list -->
            <Border Style="{StaticResource Card}"
                    Padding="0"
                    Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding RecentSessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background"
                                                        Value="{StaticResource NavHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding CreatedAt, StringFormat='MMM d, yyyy'}"
                                               Style="{StaticResource Muted}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CandidateName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="2"
                                            CornerRadius="12" Padding="12,4"
                                            VerticalAlignment="Center"
                                            Background="{Binding Status,
                                                         Converter={StaticResource SessionStatusToBrush}}">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White" FontWeight="Bold"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>