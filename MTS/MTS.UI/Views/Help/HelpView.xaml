<UserControl x:Class="MTS.UI.Views.Help.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:HelpViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="860">

                <TextBlock Text="Help &amp; Support" Style="{StaticResource H1}" Margin="0,0,0,4"/>
                <TextBlock Text="Everything you need to run mock sessions confidently."
                           Style="{StaticResource Muted}" Margin="0,0,0,24"/>

                <TabControl>

                    <!-- =================== How to Use =================== -->
                    <TabItem Header="How to Use">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="STARTING A SESSION" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
1. Open the app and navigate to <Run FontWeight="SemiBold">The Basics</Run> from the sidebar.
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
2. Enter the candidate's name, pronouns, and confirm headset / VPN / browser pre-checks.
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
3. Click <Run FontWeight="SemiBold">Continue</Run> to start the mock call sequence.
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap">
4. After all calls, complete the Supervisor Transfer, then navigate to <Run FontWeight="SemiBold">Review</Run> to finish.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="GRADING A CALL" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
Select the <Run Foreground="{StaticResource PassBrush}" FontWeight="SemiBold">PASS</Run> or <Run Foreground="{StaticResource FailBrush}" FontWeight="SemiBold">FAIL</Run> button for each call.
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
If FAIL is selected, the fail-reason section expands. Check all applicable reasons.
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap">
Add coaching notes in the Coaching section for any coaching points observed.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <!-- =================== Session Flows =================== -->
                    <TabItem Header="Session Flows">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="STANDARD FLOW" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap">
The Basics → Call 1 → Call 2 → Call 3 → Supervisor Transfer → Review → Save
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="SUPERVISOR-ONLY FLOW" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap">
The Basics (check Supervisor Only) → Supervisor Transfer → Review → Save
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="AUTO-FAIL SCENARIOS" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• <Run FontWeight="SemiBold">NC/NS</Run> — candidate never connected.</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• <Run FontWeight="SemiBold">Not Ready</Run> — candidate joined unprepared.</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• <Run FontWeight="SemiBold">VPN can't disable</Run> — VPN running and cannot be turned off.</TextBlock>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• <Run FontWeight="SemiBold">Wrong headset</Run> — non-USB headset used.</TextBlock>
                                    <TextBlock TextWrapping="Wrap">• <Run FontWeight="SemiBold">Browser not default</Run> — Chrome not set as default browser.</TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <!-- =================== FAQ =================== -->
                    <TabItem Header="FAQ">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Where is session data stored?" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}">
All data is stored locally in %AppData%\MTS\mts.db. Nothing is sent to external servers.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Can I edit a session after saving?" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}">
Sessions are read-only once saved to History. You can view details from the History screen.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="How do I update the shows / donors / fail reasons?" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}">
Navigate to Settings in the sidebar to add, edit, or remove any list items.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <!-- =================== Support =================== -->
                    <TabItem Header="Support">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="CONTACT ACD SUPPORT" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
For technical issues with MTS, reach out via the ACD Discord server in the #tech-support channel.
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}">
App Version: 1.0.0
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Button Content="← Back to Dashboard"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Left"/>
        </Border>
    </Grid>
</UserControl>
