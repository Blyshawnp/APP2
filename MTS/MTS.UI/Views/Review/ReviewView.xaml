<UserControl x:Class="MTS.UI.Views.Review.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ReviewViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24" MaxWidth="960">

                <!-- Title -->
                <TextBlock Text="Session Review &amp; Summary" Style="{StaticResource H1}" Margin="0,0,0,16"/>

                <!-- ============================================================
                     STATUS BANNER — full width, color-coded
                ============================================================ -->
                <Border CornerRadius="6" Padding="24,18" Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource PassSurfaceBrush}"/>
                            <Setter Property="BorderBrush"    Value="{StaticResource PassBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFail}" Value="True">
                                    <Setter Property="Background"    Value="{StaticResource FailSurfaceBrush}"/>
                                    <Setter Property="BorderBrush"   Value="{StaticResource FailBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsIncomplete}" Value="True">
                                    <Setter Property="Background"    Value="{StaticResource IncompleteSurfaceBrush}"/>
                                    <Setter Property="BorderBrush"   Value="{StaticResource IncompleteBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{Binding ComputedStatus, Converter={StaticResource SessionStatusToBrush}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="SESSION PASSED"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFail}" Value="True">
                                        <Setter Property="Text" Value="SESSION FAILED"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsIncomplete}" Value="True">
                                        <Setter Property="Text" Value="SESSION INCOMPLETE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- ============================================================
                     CANDIDATE INFO CARD
                ============================================================ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <TextBlock FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,0,10">
                            <Run Text="Candidate: "/>
                            <Run Text="{Binding CandidateName, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Margin="0,0,0,14">
                            <Run Text="Skills: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Run Text="{Binding SkillsLabel, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </TextBlock>

                        <!-- Auto-fail badge -->
                        <Border Background="{StaticResource FailBrush}"
                                CornerRadius="4" Padding="10,4"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasAutoFail, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding AutoFailReason, StringFormat='AUTO-FAIL: {0}'}"
                                       FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <!-- Call results -->
                        <TextBlock Text="— CALL RESULTS —"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,8"
                                   Visibility="{Binding IsSupervisorOnly, Converter={StaticResource InverseBoolToVisibility}}"/>

                        <StackPanel Margin="0,0,0,12"
                                    Visibility="{Binding IsSupervisorOnly, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Margin="0,2">
                                <Run Text="Call 1: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Run Text="{Binding Call1Result, Mode=OneWay}"
                                     Foreground="{Binding Call1Passed, Converter={StaticResource BoolToPassFailBrush}}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="Call 2: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Run Text="{Binding Call2Result, Mode=OneWay}"
                                     Foreground="{Binding Call2Passed, Converter={StaticResource BoolToPassFailBrush}}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="Call 3: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Run Text="{Binding Call3Result, Mode=OneWay}"
                                     Foreground="{Binding Call3Result, Mode=OneWay, Converter={StaticResource ResultStringToBrush}}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Sup transfer results -->
                        <TextBlock Text="— SUP TRANSFER RESULTS —"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,8"/>

                        <StackPanel>
                            <TextBlock Margin="0,2">
                                <Run Text="Transfer 1: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Run Text="{Binding Transfer1Result, Mode=OneWay}"
                                     Foreground="{Binding Transfer1Passed, Converter={StaticResource BoolToPassFailBrush}}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="Transfer 2: " FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Run Text="{Binding Transfer2Result, Mode=OneWay}"
                                     Foreground="{Binding Transfer2Result, Mode=OneWay, Converter={StaticResource ResultStringToBrush}}"/>
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ============================================================
                     COACHING SUMMARY
                ============================================================ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Coaching Summary"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,10"/>

                        <TextBox Text="{Binding CoachingSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="90" MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Copy"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,7" Margin="0,0,8,0"
                                    Command="{Binding CopyCoachingSummaryCommand}"/>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Padding="14,7"
                                    Command="{Binding RegenerateCoachingSummaryCommand}"
                                    IsEnabled="{Binding IsAiEnabled}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Regenerate"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeneratingCoachingSummary}" Value="True">
                                                    <Setter Property="Text" Value="Generating…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ============================================================
                     FAIL SUMMARY (always shown, N/A for passes)
                ============================================================ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Fail Summary"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,10"/>

                        <TextBox AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="90" MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,10">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="Text" Value="{Binding FailSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Copy"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,7" Margin="0,0,8,0"
                                    Command="{Binding CopyFailSummaryCommand}"/>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Padding="14,7"
                                    Command="{Binding RegenerateFailSummaryCommand}"
                                    IsEnabled="{Binding IsAiEnabled}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Regenerate"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeneratingFailSummary}" Value="True">
                                                    <Setter Property="Text" Value="Generating…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ================================================================
             FOOTER
        ================================================================ -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- intentionally blank left side -->
                </StackPanel>

                <!-- Fill Form (amber/orange) -->
                <Button Grid.Column="1"
                        Content="Fill Form"
                        Command="{Binding FillFormCommand}"
                        Padding="20,10" FontSize="14" FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Background" Value="#D97706"/>
                            <Setter Property="BorderBrush" Value="#D97706"/>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Save & Finish (green) -->
                <Button Grid.Column="3"
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding FinishSessionCommand}"
                        IsEnabled="{Binding CanFinish}"
                        Padding="20,10" FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Finishing…" Foreground="White"
                                   Visibility="{Binding IsFinishing, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="Save &amp; Finish Session" Foreground="White"
                                   Visibility="{Binding IsFinishing, Converter={StaticResource InverseBoolToVisibility}}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
