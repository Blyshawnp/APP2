<UserControl x:Class="MTS.UI.Views.Review.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MTS.UI.ViewModels"
             xmlns:sp="clr-namespace:MTS.UI.Controls.SummaryPanel"
             xmlns:wb="clr-namespace:MTS.UI.Controls.WarningBanner"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ReviewViewModel}"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>   <!-- Status banner -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>   <!-- Readiness warnings -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>      <!-- Scrollable content -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>   <!-- Footer actions -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             HEADER
        ================================================================ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Session Review" Style="{StaticResource H1}"/>
            <TextBlock Text="Review and edit the session summary before finishing. Nothing is saved until you click Finish."
                       Style="{StaticResource Muted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ================================================================
             STATUS BANNER
        ================================================================ -->
        <Border Grid.Row="2"
                CornerRadius="8" Padding="20,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource FailSurfaceBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource FailBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPass}" Value="True">
                            <Setter Property="Background" Value="{StaticResource PassSurfaceBrush}"/>
                            <Setter Property="BorderBrush"  Value="{StaticResource PassBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsIncomplete}" Value="True">
                            <Setter Property="Background" Value="{StaticResource IncompleteSurfaceBrush}"/>
                            <Setter Property="BorderBrush"  Value="{StaticResource IncompleteBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding StatusLabel}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{Binding ComputedStatus,
                                           Converter={StaticResource SessionStatusToBrush}}"/>
                    <TextBlock Text="{Binding CandidateName, StringFormat='Candidate: {0}'}"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="Auto-Fail"
                               FontSize="12"
                               Foreground="{StaticResource FailBrush}"
                               Margin="0,4,0,0"
                               Visibility="{Binding HasAutoFail,
                                           Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Quick stats -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CallsPassed}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PassBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Calls Passed" Style="{StaticResource Muted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SupsPassed}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sups Passed" Style="{StaticResource Muted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================================================================
             READINESS WARNINGS (informational — do not block finish)
        ================================================================ -->
        <wb:WarningBannerControl Grid.Row="4"
                                 Warnings="{Binding ReadinessWarnings}"/>

        <!-- ================================================================
             SCROLLABLE CONTENT: Summaries + Call breakdown
        ================================================================ -->
        <ScrollViewer Grid.Row="6"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Coaching Summary panel -->
                <sp:SummaryPanelControl
                    Title="Coaching Summary"
                    RegenerateLabel="Regenerate"
                    EmptyHint="No coaching notes generated. Type manually or click Regenerate."
                    SummaryText="{Binding CoachingSummary, Mode=TwoWay}"
                    IsGenerating="{Binding IsGeneratingCoachingSummary}"
                    IsAiEnabled="{Binding IsAiEnabled}"
                    RegenerateCommand="{Binding RegenerateCoachingSummaryCommand}"
                    Margin="0,0,0,16"/>

                <!-- Fail Summary panel (shown when session has a failure) -->
                <sp:SummaryPanelControl
                    Title="Fail Summary"
                    RegenerateLabel="Regenerate"
                    EmptyHint="No fail notes generated. Type manually or click Regenerate."
                    SummaryText="{Binding FailSummary, Mode=TwoWay}"
                    IsGenerating="{Binding IsGeneratingFailSummary}"
                    IsAiEnabled="{Binding IsAiEnabled}"
                    RegenerateCommand="{Binding RegenerateFailSummaryCommand}"
                    Visibility="{Binding IsFail, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,16"/>

                <!-- Session detail table -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Session Detail" Style="{StaticResource H3}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Candidate" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CandidateName}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Session Type" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding IsSupervisorOnly,
                                              Converter={StaticResource EnumEquality},
                                              ConverterParameter=True}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Calls Passed" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CallsPassed}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Sups Passed" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SupsPassed}"/>
                        </Grid>

                        <!-- Newbie shift scheduled indicator -->
                        <Border Margin="0,12,0,0"
                                Background="{StaticResource IncompleteSurfaceBrush}"
                                BorderBrush="{StaticResource IncompleteBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,8"
                                Visibility="{Binding HasNewbieShift,
                                            Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="⏰  Newbie shift scheduled"
                                       Foreground="{StaticResource IncompleteBrush}"
                                       FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ================================================================
             FOOTER ACTIONS
             Critical: Finish button is the ONLY submission path (BR-10).
        ================================================================ -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Copy review -->
            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CopyReviewCommand}"
                    Content="Copy Review"
                    Padding="16,10"/>

            <!-- Spacer note -->
            <TextBlock Grid.Column="2"
                       Text="Review the summary above before finishing. This action cannot be undone."
                       Style="{StaticResource Muted}"
                       VerticalAlignment="Center"/>

            <!-- Finish Session — explicit user action required (BR-10) -->
            <Button Grid.Column="3"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding FinishSessionCommand}"
                    IsEnabled="{Binding CanFinish}"
                    Padding="24,10" FontSize="14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Finishing…" Margin="0,0,0,0"
                               Visibility="{Binding IsFinishing,
                                           Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Finish Session ✓"
                               Visibility="{Binding IsFinishing,
                                           Converter={StaticResource InverseBoolToVisibility}}"/>
                </StackPanel>
            </Button>
        </Grid>

    </Grid>
</UserControl>
