<Window x:Class="MTS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MTS.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
        Title="Mock Testing Suite"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="Auto"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================================
             SIDEBAR
        ================================================================ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Width="220">
            <DockPanel>

                <!-- Logo / App Name -->
                <Border DockPanel.Dock="Top"
                        Padding="16,20,16,16"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="32" Height="32"
                                 Fill="{StaticResource AccentBrush}"
                                 Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MTS"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Mock Testing Suite"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Active Session Indicator -->
                <Border DockPanel.Dock="Top"
                        Padding="12,10"
                        Margin="8,8,8,0"
                        CornerRadius="6"
                        Background="{StaticResource AccentBrush}"
                        Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE SESSION"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="White" Opacity="0.8"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding SessionCandidateName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <StackPanel DockPanel.Dock="Top" Margin="8,12,8,0">

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding GoToDashboardCommand}"
                            HorizontalContentAlignment="Left"
                            Margin="0,1" Padding="12,10">
                        <TextBlock Text="⌂  Dashboard" FontSize="13"/>
                    </Button>

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding GoToCallsCommand}"
                            IsEnabled="{Binding IsSessionActive}"
                            HorizontalContentAlignment="Left"
                            Margin="0,1" Padding="12,10">
                        <TextBlock Text="☎  Calls" FontSize="13"/>
                    </Button>

                </StackPanel>

                <!-- Bottom: Discard + Version -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                    <Separator/>
                    <Button Style="{StaticResource DangerButton}"
                            Command="{Binding DiscardSessionCommand}"
                            Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVisibility}}"
                            Content="Discard Session"
                            Margin="0,4" Padding="12,8"
                            FontSize="12"/>
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                               Style="{StaticResource Muted}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ================================================================
             MAIN CONTENT AREA
        ================================================================ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content host — DataTemplate auto-selects the correct View -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource AppBackgroundBrush}">
                <ContentControl Content="{Binding CurrentViewModel}"
                                Margin="0"/>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,6">
                <TextBlock Text="{Binding AppVersion, StringFormat='Mock Testing Suite v{0}'}"
                           Style="{StaticResource Muted}"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>

</Window>
