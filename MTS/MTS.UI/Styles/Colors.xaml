<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background hierarchy -->
    <SolidColorBrush x:Key="AppBackgroundBrush"    Color="#0F0F13"/>
    <SolidColorBrush x:Key="SurfaceBrush"          Color="#1A1A24"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush"  Color="#22222F"/>
    <SolidColorBrush x:Key="SidebarBrush"          Color="#13131A"/>
    <SolidColorBrush x:Key="BorderBrush"           Color="#2E2E40"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="#F0F0F8"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"    Color="#9090A8"/>
    <SolidColorBrush x:Key="TextMutedBrush"        Color="#55556A"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"     Color="#FFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"           Color="#7C6AF7"/>
    <SolidColorBrush x:Key="AccentHoverBrush"      Color="#9080FF"/>
    <SolidColorBrush x:Key="AccentPressedBrush"    Color="#6050D0"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="PassBrush"             Color="#22C55E"/>
    <SolidColorBrush x:Key="PassSurfaceBrush"      Color="#14271E"/>
    <SolidColorBrush x:Key="FailBrush"             Color="#EF4444"/>
    <SolidColorBrush x:Key="FailSurfaceBrush"      Color="#2A1515"/>
    <SolidColorBrush x:Key="IncompleteBrush"       Color="#F59E0B"/>
    <SolidColorBrush x:Key="IncompleteSurfaceBrush" Color="#291E0A"/>
    <SolidColorBrush x:Key="WarningBrush"          Color="#F59E0B"/>
    <SolidColorBrush x:Key="WarningSurfaceBrush"   Color="#1F1A08"/>
    <SolidColorBrush x:Key="InfoBrush"             Color="#3B82F6"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush"  Color="#1A1A28"/>
    <SolidColorBrush x:Key="InputBorderBrush"      Color="#34344A"/>
    <SolidColorBrush x:Key="InputFocusBrush"       Color="#7C6AF7"/>

    <!-- Sidebar selected -->
    <SolidColorBrush x:Key="NavSelectedBrush"      Color="#2A2540"/>
    <SolidColorBrush x:Key="NavHoverBrush"         Color="#1E1E30"/>

    <!-- Scalars -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">12</CornerRadius>

</ResourceDictionary>
