<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: self-contained single-file Windows x64 release build.
  Usage:
    dotnet publish MTS.UI\MTS.UI.csproj -p:PublishProfile=Release
  Or via build.ps1 (recommended):
    .\build.ps1
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>

    <!-- Output goes to MTS\publish\win-x64\ -->
    <PublishDir>..\..\publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>

    <!-- Self-contained: bundles .NET 8 runtime, no prerequisites for end users -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>

    <!-- Single-file exe -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>

    <!-- AOT-style startup speed improvement (no IL recompilation at runtime) -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- Embed PDB inside exe; keeps publish folder clean -->
    <DebugType>embedded</DebugType>

    <!-- Do NOT trim — WPF relies heavily on reflection -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
